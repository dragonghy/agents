# Agent-Hub Environment Configuration
# Copy this file to .env and fill in your values.

# Leantime
LEANTIME_URL=http://localhost:9090
LEANTIME_API_KEY=your_leantime_api_key_here
LEANTIME_USER_EMAIL=your_email@example.com

# MySQL (used by services/leantime/docker-compose.yml)
MYSQL_ROOT_PASSWORD=change_me_to_strong_password
MYSQL_PASSWORD=change_me_to_strong_password
LEAN_SESSION_PASSWORD=change_me_to_random_string

# Workspace: root directory for external project repos.
# Agents reference projects as ${WORKSPACE_DIR}/project-name in add_dirs.
# Only projects that exist on disk are mounted; missing ones are skipped.
WORKSPACE_DIR=~/workspace
