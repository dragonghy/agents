# Agent-Hub Environment Configuration
# Copy this file to .env and fill in your values.

# Docker: Web UI port (default: 3000)
# WEB_PORT=3000

# Workspace: root directory for external project repos.
# Agents reference projects as ${WORKSPACE_DIR}/project-name in add_dirs.
# Only projects that exist on disk are mounted; missing ones are skipped.
WORKSPACE_DIR=~/workspace

# --- Docker Agent Mode (docker compose --profile agents up) ---
# Set ONE of these to authenticate Claude Code in containers.

# OAuth token (recommended) — run `claude setup-token` locally to generate
# CLAUDE_CODE_OAUTH_TOKEN=

# API key (alternative) — from console.anthropic.com
# ANTHROPIC_API_KEY=

# --- Telegram channel adapter (services/telegram-bot/) ---
# Required to run the bot. Get a token from @BotFather.
# TELEGRAM_BOT_TOKEN=

# Allow-listed Telegram chat id for the Human (numeric).
# Get yours by sending /start to @userinfobot. Used by the bot to
# allow-list inbound messages and by the daemon's morning-brief loop
# to know which Telegram channel to spawn the secretary against.
# Either name works; HUMAN_TELEGRAM_CHAT_ID is preferred for the daemon
# side, TELEGRAM_HUMAN_CHAT_ID is the legacy alias used by the bot.
# HUMAN_TELEGRAM_CHAT_ID=
# TELEGRAM_HUMAN_CHAT_ID=

# Daemon URL the bot talks to. Defaults to http://127.0.0.1:8765.
# DAEMON_URL=http://127.0.0.1:8765

# Default Profile spawned for new human-channel sessions.
# DEFAULT_PROFILE=secretary
