# ── Management Plane Configuration ──

# Environment: "development" or "production"
MGMT_ENV=development

# Server
MGMT_HOST=0.0.0.0
MGMT_PORT=3000

# Database path (SQLite)
MGMT_DB_PATH=management.db

# Instance Manager
MGMT_MOCK_MODE=true       # Set to "false" for real Docker Compose deployments
MGMT_INSTANCES_DIR=/var/lib/aghub/instances
MGMT_PORT_START=10000
MGMT_PORT_MAX=10999

# ── Security (REQUIRED for production) ──

# JWT signing secret (min 32 characters)
JWT_SECRET=CHANGE-ME-to-a-secure-random-string-at-least-32-chars

# Encryption key for auth tokens stored in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or use any passphrase (will be derived via PBKDF2)
MGMT_ENCRYPT_KEY=

# Shared secret for instance daemon → management plane usage reporting
MGMT_USAGE_SECRET=CHANGE-ME-to-a-secure-random-string

# ── Domain (for production CORS + Nginx) ──

MGMT_DOMAIN=agenthub.cloud

# ── Stripe (optional, for billing) ──

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Repo root (for Docker build context) ──

MGMT_REPO_ROOT=/opt/agents
