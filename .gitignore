# Credentials and local config
.env

# Python
__pycache__/
*.pyc
.venv/

# Node.js
node_modules/
dist/

# Runtime data
*.db
*.db-shm
*.db-wal
data/

# Agent runtime files (generated by setup-agents.py)
.mcp.json
.agent-sessions
agents/shared/team-roster.md
agents/*/.claude/

# Generated instance agent definitions (e.g. dev-alex.md, qa-lucy.md)
# Template definitions (product.md, dev.md, etc.) are tracked in git.
.claude/agents/*-*.md

# Generated agent instance directories (product-kevin, dev-alex, qa-lucy, etc.)
# Template dirs (admin, product, dev, qa, user) are tracked in git.
# Instance dirs (with hyphen) are auto-generated by setup-agents.py.
agents/*-*/

# Tester agent template (E2E testing only)
agents/tester/

# Frontend build output (generated by npm run build in services/agents-mcp/web/)
services/agents-mcp/src/agents_mcp/web/static/

# Daemon runtime files
.daemon.log
.daemon.pid

# OS files
.DS_Store
Thumbs.db
