# Credentials and local config
.env

# Python
__pycache__/
*.pyc
.venv/

# Node.js
node_modules/
dist/

# Runtime data
*.db
*.db-shm
*.db-wal
data/

# Agent workspaces (entirely generated by setup-agents.py)
# Template sources live in templates/, not agents/.
/agents/
.mcp.json
.agent-sessions

# Generated instance agent definitions (e.g. dev-alex.md, qa-lucy.md)
# Template definitions (product.md, dev.md, etc.) are tracked in git.
.claude/agents/*-*.md

# Frontend build output (generated by npm run build in services/agents-mcp/web/)
services/agents-mcp/src/agents_mcp/web/static/

# Daemon runtime files
.daemon.log
.daemon.log.prev
.daemon.pid
.watchdog.log

# Test outputs (screenshots, results)
test-results/
tests/screenshots/
**/screenshots/*.png

# External projects (managed in their own repos)
projects/shopify-seo-app/
projects/showcase/
projects/seopilot-landing/
projects/seopilot-chrome-ext/
projects/business-research/
projects/pomodoro-timer/

# OS files
.DS_Store
Thumbs.db
briefs/
tmp/
