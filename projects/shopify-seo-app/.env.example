# Shopify App credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# App URL
# Local development: http://localhost:3456
# Production (Vercel): https://seopilot.vercel.app
SHOPIFY_APP_URL=http://localhost:3456

# Scopes (comma-separated)
SCOPES=read_products,write_products,read_content,write_content

# Database URL (PostgreSQL)
# Local: postgresql://postgres:postgres@localhost:5432/seopilot?schema=public
# Production: Use Neon, Supabase, or other managed PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seopilot?schema=public

# OpenAI API Key (for AI SEO fix generation)
# Without this key, AI features fall back to mock/template mode
OPENAI_API_KEY=your_openai_key_here

# ──────────────────────────────────────────────
# Vercel Deployment Notes
# ──────────────────────────────────────────────
# All env vars above must be set in Vercel dashboard:
#   Settings → Environment Variables
#
# Required for production:
#   SHOPIFY_API_KEY      - From Shopify Partners
#   SHOPIFY_API_SECRET   - From Shopify Partners
#   SHOPIFY_APP_URL      - Your Vercel deployment URL
#   SCOPES               - read_products,write_products,read_content,write_content
#   DATABASE_URL         - External PostgreSQL (Neon/Supabase recommended)
#   OPENAI_API_KEY       - OpenAI API key for AI features
#   NODE_ENV             - "production" (set in vercel.json)
